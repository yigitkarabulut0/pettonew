{
  "expo": {
    "name": "Petto",
    "slug": "petto-mobile",
    "scheme": "petto",
    "version": "0.9.2",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      "expo-image-picker",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Petto uses your current location to show nearby pet matches."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.petto.mobile"
    }
  }
}
